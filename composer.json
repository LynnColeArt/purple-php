{
  "name": "purple-php/sdk",
  "description": "Enterprise AI modernization SDK for PHP applications.",
  "type": "library",
  "license": "MIT",
  "bin": [
    "bin/purple"
  ],
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "Purple\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Purple\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "analyse": "phpstan analyse --memory-limit=1G",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "format": "php-cs-fixer fix",
    "check": [
      "@test",
      "@analyse",
      "@lint"
    ]
  }
}
