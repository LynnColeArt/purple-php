{
  "name": "purple-php/provider-bedrock",
  "description": "Optional AWS Bedrock provider adapter for Purple PHP.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "purple-php/sdk": "0.1.x-dev"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.75",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11.5"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../..",
      "options": {
        "symlink": true,
        "versions": {
          "purple-php/sdk": "0.1.x-dev"
        }
      }
    }
  ],
  "autoload": {
    "psr-4": {
      "Purple\\Provider\\Bedrock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Purple\\Provider\\Bedrock\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "scripts": {
    "test": "phpunit -c phpunit.xml.dist",
    "analyse": "phpstan analyse --memory-limit=1G",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "format": "php-cs-fixer fix",
    "check": [
      "@test",
      "@analyse",
      "@lint"
    ]
  }
}
